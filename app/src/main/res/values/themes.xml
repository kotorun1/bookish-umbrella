<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TwitchStreamAlarm" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/twitch_purple</item>
        <item name="colorPrimaryVariant">@color/twitch_purple_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Dark theme for alarm screen -->
    <style name="Theme.TwitchStreamAlarm.Alarm" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@color/alarm_background</item>
        <item name="android:statusBarColor">@color/alarm_background</item>
        <item name="android:navigationBarColor">@color/alarm_background</item>
        <item name="colorPrimary">@color/twitch_purple</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowShowWallpaper">false</item>
        <item name="android:windowTranslucentStatus">false</item>
    </style>
</resources>
