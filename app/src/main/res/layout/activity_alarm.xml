<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/alarm_background"
    android:padding="32dp">

    <!-- Animated Twitch logo emoji -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📺"
        android:textSize="80sp"
        android:layout_marginBottom="8dp"/>

    <!-- Live badge -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="@color/live_red"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp">

        <TextView
            android:id="@+id/tvLiveBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔴 В ЭФИРЕ"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:letterSpacing="0.06"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Streamer name -->
    <TextView
        android:id="@+id/tvStreamerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Стример"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <!-- Stream title -->
    <TextView
        android:id="@+id/tvStreamTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="16sp"
        android:textColor="@color/alarm_text_secondary"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginBottom="8dp"/>

    <!-- Meta: game + viewers -->
    <TextView
        android:id="@+id/tvMeta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:textColor="@color/twitch_purple_light"
        android:gravity="center"
        android:layout_marginBottom="48dp"/>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Watch button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWatch"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶  Смотреть стрим"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            app:backgroundTint="@color/twitch_purple"
            app:cornerRadius="16dp"/>

        <!-- Dismiss button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDismiss"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Закрыть будильник"
            android:textSize="15sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/alarm_text_secondary"
            android:textColor="@color/alarm_text_secondary"
            app:cornerRadius="16dp"/>
    </LinearLayout>
</LinearLayout>